{
  "name": "formosa-admin",
  "version": "1.0.0",
  "description": "Admin panel for Formoza-Service",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "init": "node init-db.js",
    "migrate": "npx knex migrate:latest --knexfile knexfile.js",
    "seed": "npx knex seed:run --knexfile knexfile.js",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^2.5.1",
    "multer": "^2.1.1",
    "pg": "^8.11.1",
    "sqlite3": "^6.0.1"
  }
}
